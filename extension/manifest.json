{
  "manifest_version": 3,

  "name": "ShadowGuard",

  "version": "1.0",

  "description": "Prevents sensitive data leakage through AI tools",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://chatgpt.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],

      "js": [
        "content.js"
      ],

      "css": [
        "styles.css"
      ],

      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}